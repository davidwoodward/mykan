# Copy this file to .env.local and fill in the values.
# See ENV_SETUP.md for where each value comes from.

# --- Auth.js -------------------------------------------------------------
# Generate locally with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Supabase (server-only — no NEXT_PUBLIC_ prefix on purpose) ----------
# Settings → API in the Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional ------------------------------------------------------------
# Override the hardcoded whitelist (comma-separated, lowercase, no spaces)
# AUTH_ALLOWED_EMAILS=dawoodward@gmail.com,matthewl@experiencealign.com

# --- MCP (Claude Code integration; see docs/mcp-setup.md) ----------------
# Bearer key(s) for /api/mcp (comma-separated to rotate).
# Generate: printf 'mykan_sk_%s' "$(openssl rand -base64 32)"
MYKAN_SERVICE_API_KEY=

# Optional: identity the MCP acts as (defaults to the owner email).
MCP_ACTOR_EMAIL=dawoodward@gmail.com

# --- Telegram bot (see docs/telegram-setup.md) ---------------------------
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Random secret echoed back by Telegram on every webhook call (forgery guard).
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated numeric chat/user ids allowed to drive the bot. Message the
# bot once and it replies with your chat id, then put it here.
TELEGRAM_ALLOWED_CHAT_IDS=
