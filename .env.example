# Copy this file to .env.local and fill in the values.
# See ENV_SETUP.md for where each value comes from.

# --- Auth.js -------------------------------------------------------------
# Generate locally with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Supabase (server-only — no NEXT_PUBLIC_ prefix on purpose) ----------
# Settings → API in the Supabase dashboard
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional ------------------------------------------------------------
# Override the hardcoded whitelist (comma-separated, lowercase, no spaces)
# AUTH_ALLOWED_EMAILS=dawoodward@gmail.com,matthewl@experiencealign.com
